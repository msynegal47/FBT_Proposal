<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FBT Filming Guide - Session 1</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1C2B3A;
    --blush: #C9967F;
    --blush-light: #F2DDD6;
    --gold: #C9A96E;
    --cream: #FAF7F2;
    --white: #FFFFFF;
    --gray: #6B6560;
    --light-gray: #F0EBE5;
    --border: #E2D9D2;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--cream);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    color: var(--navy);
    padding: 40px 24px;
    max-width: 780px;
    margin: 0 auto;
  }

  /* TOP NAV */
  .top-nav {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 48px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .nav-link {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid var(--border);
    border-radius: 100px;
    transition: all 0.2s;
  }
  .nav-link:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
  .nav-link.active { background: var(--blush); color: var(--white); border-color: var(--blush); }

  /* HEADER */
  .page-header {
    margin-bottom: 56px;
  }

  .page-eyebrow {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .page-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .page-subtitle {
    font-size: 14px;
    color: var(--gray);
  }

  /* SECTION LABEL */
  .section-label {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--blush);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--blush-light);
    display: block;
  }

  /* SETUP SECTION */
  .setup-section {
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--navy);
    padding: 40px;
    margin-bottom: 56px;
  }

  .setup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 28px;
  }

  .setup-block h3 {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blush);
    margin-bottom: 14px;
  }

  .setup-block ul {
    list-style: none;
  }

  .setup-block ul li {
    font-size: 13px;
    color: var(--gray);
    padding: 7px 0;
    border-bottom: 1px solid var(--light-gray);
    display: flex;
    gap: 10px;
    line-height: 1.5;
  }

  .setup-block ul li::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
    margin-top: 7px;
  }

  .setting-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 7px 0;
    border-bottom: 1px solid var(--light-gray);
    gap: 16px;
  }

  .setting-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--navy);
    flex-shrink: 0;
  }

  .setting-value {
    font-size: 12px;
    color: var(--gray);
    text-align: right;
  }

  .setup-note {
    background: var(--light-gray);
    padding: 14px 18px;
    margin-top: 16px;
    font-size: 12px;
    color: var(--gray);
    font-style: italic;
    line-height: 1.6;
    border-left: 2px solid var(--blush);
  }

  /* BUCKET HEADER */
  .bucket-header {
    margin: 56px 0 28px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .bucket-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 400;
    color: var(--blush-light);
    line-height: 1;
    flex-shrink: 0;
  }

  .bucket-info h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 600;
    color: var(--navy);
  }

  .bucket-info p {
    font-size: 12px;
    color: var(--gray);
    margin-top: 4px;
  }

  /* VIDEO CARD */
  .video-card {
    background: var(--white);
    border: 1px solid var(--border);
    margin-bottom: 24px;
    page-break-inside: avoid;
    break-inside: avoid;
  }

  .card-header {
    padding: 24px 32px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .card-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    color: var(--blush);
    letter-spacing: 0.1em;
  }

  .card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--navy);
    flex: 1;
  }

  .format-badge {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    flex-shrink: 0;
  }

  .badge-duo { background: var(--navy); color: var(--white); }
  .badge-nichole { background: var(--blush); color: var(--white); }
  .badge-jalyn { background: var(--gold); color: var(--white); }

  .card-body {
    padding: 28px 32px;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 32px;
  }

  /* CARD LEFT */
  .card-left {}

  .card-section-title {
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--blush);
    margin-bottom: 12px;
    display: block;
  }

  .gear-list, .check-list {
    list-style: none;
    margin-bottom: 24px;
  }

  .gear-list li, .check-list li {
    font-size: 12px;
    color: var(--gray);
    padding: 6px 0;
    border-bottom: 1px solid var(--light-gray);
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.5;
  }

  .gear-list li::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
    margin-top: 6px;
  }

  .check-list li::before {
    content: '☐';
    font-size: 13px;
    color: var(--blush);
    flex-shrink: 0;
    line-height: 1.3;
  }

  .runtime-tag {
    display: inline-block;
    background: var(--light-gray);
    padding: 4px 10px;
    font-size: 11px;
    color: var(--navy);
    border-radius: 4px;
    margin-top: 4px;
  }

  /* CARD RIGHT - SCRIPT */
  .card-right {}

  .script-block {
    margin-bottom: 12px;
  }

  .script-speaker {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blush);
    margin-bottom: 4px;
  }

  .script-line {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px;
    font-style: italic;
    color: var(--navy);
    line-height: 1.65;
    padding-left: 12px;
    border-left: 2px solid var(--blush-light);
  }

  .disclaimer-block {
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--light-gray);
    border-left: 2px solid var(--gold);
  }

  .disclaimer-block .script-speaker {
    color: var(--gold);
  }

  .disclaimer-block .script-line {
    font-size: 14px;
    border-left: none;
    padding-left: 0;
    color: var(--gray);
  }

  /* DELIVERY SECTION */
  .delivery-section {
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--blush);
    padding: 40px;
    margin-top: 56px;
  }

  .folder-structure {
    background: var(--navy);
    padding: 24px 28px;
    margin-top: 20px;
    font-family: monospace;
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    line-height: 2;
    border-radius: 2px;
  }

  .folder-structure .folder {
    color: var(--gold);
  }

  .folder-structure .sub {
    padding-left: 24px;
    color: rgba(255,255,255,0.6);
  }

  .delivery-note {
    font-size: 13px;
    color: var(--gray);
    line-height: 1.7;
    margin-top: 20px;
  }

  .delivery-note strong {
    color: var(--navy);
    font-weight: 500;
  }

  /* FOOTER */
  .doc-footer {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .doc-footer p {
    font-size: 12px;
    color: var(--gray);
  }

  .doc-footer a {
    font-size: 12px;
    color: var(--blush);
    text-decoration: none;
  }

  @media print {
    .top-nav { display: none; }
    .video-card { page-break-inside: avoid; }
    body { padding: 20px; }
  }

  @media (max-width: 600px) {
    .card-body { grid-template-columns: 1fr; }
    .setup-grid { grid-template-columns: 1fr; }
    .card-header { flex-wrap: wrap; }
  }
</style>
</head>
